# ---------------------------------------------------------------------------
# Langswytch .env template — copy to `.env` and fill in your own keys.
# Do NOT commit `.env` (it is in .gitignore).
# ---------------------------------------------------------------------------

# Required: OpenAI API key for the LangGraph agent's LLM.
OPENAI_API_KEY=sk-...

# Optional: override the default model (must support tool calls).
# SWYTCHCODE_AGENT_MODEL=gpt-4o-mini

# Optional: subprocess timeout in seconds (default 120).
# SWYTCHCODE_TIMEOUT=120

# ---------------------------------------------------------------------------
# Service credentials — add only the ones you need, matching what is enabled
# in .swytchcode/tooling.json. These reach the Swytchcode CLI via os.environ.
# ---------------------------------------------------------------------------

# Circle (W3S programmable wallets) — e.g. w3s.* tools
# CIRCLE_API_KEY="TEST_API_KEY:<hex>:<hex>"
# CIRCLE_WALLET_SET_ID=<wallet_set_id>

# Resend (transactional email) — e.g. emails.email.create
# RESEND_API_KEY=re_...
# FROM_EMAIL=you@your-verified-domain.com

# Persona (KYC) — e.g. inquiries.*, verifications.*
# PERSONA_API_KEY=persona_sandbox_...
# PERSONA_TEMPLATE_ID=itmpl_...

# Bridge — e.g. customers.*, transfers.*
# BRIDGE_API_KEY=...

# Stripe — e.g. payment_intents.payment_intent.create
# STRIPE_API_KEY=sk_test_...

# Binance — e.g. sapi.v1.*
# BINANCE_API_KEY=...
# BINANCE_SECRET_KEY=...
