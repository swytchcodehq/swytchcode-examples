{
  "editor": "none",
  "integrations": {
    "atlassian.jira": {
      "version": "1001.0.0-snapshot"
    },
    "github.github_api": {
      "version": "1.1.4"
    },
    "slack.web_api": {
      "version": "2.0"
    }
  },
  "mode": "production",
  "tools": {
    "repos.issue.create": {
      "desc": "Create an issue in a GitHub repository",
      "inputs": [
        {
          "owner": {
            "LOCATION": "path",
            "REQUIRED": true,
            "TYPE": "STRING"
          }
        },
        {
          "repo": {
            "LOCATION": "path",
            "REQUIRED": true,
            "TYPE": "STRING"
          }
        },
        {
          "body": {
            "LOCATION": "body",
            "REQUIRED": true,
            "TYPE": "OBJECT",
            "schema": {
              "properties": {
                "title": {
                  "required": true,
                  "type": "string"
                },
                "body": {
                  "required": false,
                  "type": "string"
                },
                "labels": {
                  "required": false,
                  "type": "array"
                },
                "assignees": {
                  "required": false,
                  "type": "array"
                },
                "milestone": {
                  "required": false,
                  "type": "integer"
                }
              }
            }
          }
        }
      ],
      "integration": "github.github_api@1.1.4",
      "method_hash": "",
      "output": {
        "schema": {
          "properties": {
            "id": {
              "required": true,
              "type": "integer"
            },
            "number": {
              "required": true,
              "type": "integer"
            },
            "html_url": {
              "required": true,
              "type": "string"
            },
            "title": {
              "required": true,
              "type": "string"
            },
            "state": {
              "required": true,
              "type": "string"
            }
          }
        },
        "status": 201
      },
      "summary": "Create a GitHub issue",
      "type": "method"
    },
    "rest.api.issue.create": {
      "desc": "Create a Jira issue",
      "inputs": [
        {
          "body": {
            "LOCATION": "body",
            "REQUIRED": true,
            "TYPE": "OBJECT",
            "schema": {
              "properties": {
                "fields": {
                  "required": true,
                  "type": "object"
                },
                "update": {
                  "required": false,
                  "type": "object"
                }
              }
            }
          }
        }
      ],
      "integration": "atlassian.jira@1001.0.0-snapshot",
      "method_hash": "",
      "output": {
        "schema": {
          "properties": {
            "id": {
              "required": true,
              "type": "string"
            },
            "key": {
              "required": true,
              "type": "string"
            },
            "self": {
              "required": true,
              "type": "string"
            }
          }
        },
        "status": 201
      },
      "summary": "Create a Jira issue",
      "type": "method",
      "base_url": "https://swytchcodetest.atlassian.net"
    },
    "chat.postmessage.chat.postmessage.create": {
      "desc": "Sends a message to a channel",
      "inputs": [
        {
          "body": {
            "LOCATION": "body",
            "REQUIRED": true,
            "TYPE": "OBJECT",
            "schema": {
              "properties": {
                "channel": {
                  "required": true,
                  "type": "string"
                },
                "text": {
                  "required": false,
                  "type": "string"
                },
                "blocks": {
                  "required": false,
                  "type": "array"
                },
                "attachments": {
                  "required": false,
                  "type": "array"
                }
              }
            }
          }
        }
      ],
      "integration": "slack.web_api@2.0",
      "method_hash": "",
      "output": {
        "schema": {
          "properties": {
            "ok": {
              "required": true,
              "type": "boolean"
            },
            "channel": {
              "required": false,
              "type": "string"
            },
            "ts": {
              "required": false,
              "type": "string"
            }
          }
        },
        "status": 200
      },
      "summary": "Post a message to Slack",
      "type": "method"
    }
  },
  "version": "1"
}