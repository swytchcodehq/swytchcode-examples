# ── Swytchcode ────────────────────────────────────────────────────────────────
# Firebase JWT token. Expires in 1 hour — refresh before demo with: swytchcode whoami
SWYTCHCODE_TOKEN=

# ── Plaid Sandbox ─────────────────────────────────────────────────────────────
# Get from: https://dashboard.plaid.com → Team Settings → Keys
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_VERSION=2020-09-14

# ── Persona Sandbox ───────────────────────────────────────────────────────────
# Get from: https://app.withpersona.com → API → API Keys
PERSONA_API_KEY=
# Template ID from Persona dashboard (Templates → copy the tmpl_xxx ID)
PERSONA_TEMPLATE_ID=

# ── Dwolla Sandbox ────────────────────────────────────────────────────────────
# Get from: https://accounts-sandbox.dwolla.com → Applications → your app
DWOLLA_APP_KEY=
DWOLLA_APP_SECRET=

# ── Demo user (used for Persona + Dwolla customer creation) ───────────────────
USER_NAME=John Smith
USER_EMAIL=john@example.com

# ── Policy thresholds (optional — defaults shown) ────────────────────────────
# Transfer hold kicks in when Plaid available balance exceeds this amount
TRANSFER_HOLD_THRESHOLD=1000.0
