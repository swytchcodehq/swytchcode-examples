# Copy to .env and fill in. NEVER commit .env. Use Stripe TEST keys only.

# --- Stripe (TEST MODE) ---
# From the Stripe dashboard in test mode: Developers > API keys > Secret key (sk_test_...)
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# --- Swytchcode canonical IDs (verified end-to-end against the stripe.sdk bundle) ---
# These exact strings are what you pass to `swytchcode exec` / the scripts.
# (Confirmed via a real refund: re_... 200 OK in the Stripe test dashboard.)
SWX_REFUND_ID=refunds.refund.create
SWX_CREATE_CHARGE_ID=charges.charge.create
# Optional, if your flow retrieves the payment first:
# SWX_LOOKUP_ID=charges.charge.retrieve

# --- Demo inputs (test data) ---
# A test charge id (ch_...) to refund. Create one with: bash scripts/reset.sh --execute
DEMO_CHARGE_ID=ch_REPLACE_ME
# Refund amount in the smallest currency unit (cents). Integer. Must be <= the charge amount.
DEMO_REFUND_AMOUNT=2000
# Stripe test card token used by reset.sh to create a chargeable source. tok_visa is Stripe's standard test token.
DEMO_SOURCE_TOKEN=tok_visa

# =====================================================================
# Multi-API workflow demo (v2): HubSpot -> Stripe -> Resend
# See WORKFLOW-DEMO-PLAN.md. Fill these after `swytchcode search/get/add`.
# =====================================================================

# --- HubSpot (CRM) ---
# Private app token from HubSpot: Settings > Integrations > Private Apps (pat-...)
HUBSPOT_PRIVATE_APP_TOKEN=pat-REPLACE_ME

# --- Resend (transactional email API) ---
# API key from resend.com/api-keys (re_...). Use a test/sandbox key + a verified test domain.
RESEND_API_KEY=re_REPLACE_ME

# --- Workflow canonical IDs (ground truth from `swytchcode list tooling`) ---
SWX_HUBSPOT_CREATE_CONTACT=hubspot_crm_contacts.crm.contacts.create
SWX_STRIPE_CREATE_CUSTOMER=customers.customer.create
SWX_RESEND_SEND_EMAIL=emails.email.create
# Stripe charge step reuses SWX_CREATE_CHARGE_ID above (charges.charge.create)

# --- Workflow demo inputs (test data) ---
DEMO_LEAD_EMAIL=test@your-verified-domain.com
DEMO_LEAD_NAME=Test Lead
DEMO_PLAN_AMOUNT=2000
