# Google Sheets — https://developers.google.com/identity/protocols/oauth2
# GOOGLE_ACCESS_TOKEN: short-lived OAuth2 bearer token (run `gcloud auth print-access-token` or use a service account)
GOOGLE_ACCESS_TOKEN=ya29...
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id  # from the Sheets URL: /spreadsheets/d/<ID>/edit
GOOGLE_SHEETS_RANGE=Sheet1!A1:B10          # A1 notation range to read (header row + data rows)

# Notion — https://www.notion.so/my-integrations
NOTION_API_KEY=secret_.
# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key

# Report destination email
REPORT_EMAIL=your_email@example.com

# Notion database — open the DB page in Notion, copy the ID from the URL
NOTION_DATABASE_ID=your_notion_database_id

# Swytchcode — run `swytchcode whoami` to get your token
SWYTCHCODE_TOKEN=your_swytchcode_token
